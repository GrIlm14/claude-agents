# ╔══════════════════════════════════════════════════════════╗
# ║  claude-agents v3 — Pipeline Configuration              ║
# ╠══════════════════════════════════════════════════════════╣
# ║  Edit this file to customize your multi-agent pipeline  ║
# ║  Changes take effect on next ./claude-pipeline start    ║
# ╚══════════════════════════════════════════════════════════╝

# ── AGENT CONFIGURATION ─────────────────────────────────────
# Options: 2-agent, 3-agent, 5-agent, 6-agent, custom
AGENT_PROFILE="3-agent"

# ── MODEL ASSIGNMENTS ───────────────────────────────────────
MODEL_MANAGER="opus"
MODEL_CODER="sonnet"
MODEL_TESTER="haiku"
MODEL_SECURITY="sonnet"
MODEL_DOCS="haiku"
MODEL_SENIOR_DEV="sonnet"
MODEL_JUNIOR_DEV="haiku"

# ── RATE LIMITING & PACING ──────────────────────────────────
POLL_INTERVAL=5
CYCLE_COOLDOWN=30
MAX_CYCLES=0

# ── PERMISSIONS ─────────────────────────────────────────────
# Auto-accept all agent permissions (--dangerously-skip-permissions)
# WARNING: Agents can execute any operation without asking
# Can also be enabled per-session with: ./claude-pipeline auto --yolo
SKIP_PERMISSIONS=false

# ── TMUX LAYOUT ─────────────────────────────────────────────
# Options: horizontal, vertical, tiled
TMUX_LAYOUT="horizontal"
SESSION_NAME="claude-agents"

# ── TOKEN MANAGEMENT ────────────────────────────────────────
ARCHIVE_THRESHOLD=100
ARCHIVE_KEEP_LINES=20

# ── CUSTOM AGENTS (only when AGENT_PROFILE="custom") ───────
# Format: ROLE:MODEL:PANE_LABEL:EMOJI
# First agent is always the manager.
# Drop matching .md files in .claude/prompts/ for each role.
CUSTOM_AGENTS=()
